{
  "name": "filter",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run format:check",
    "export": "ts-node ./src/scripts/export.ts",
    "export-all": "ts-node ./src/scripts/exportAll.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preexport": "npm run generate-types && npm run generate-sound-types && npm run sync-sounds",
    "preexport-all": "npm run generate-types && npm run generate-sound-types && npm run sync-sounds",
    "update-basetypes": "ts-node ./src/scripts/updateBaseTypes.ts",
    "generate": "npm run generate-types && npm run generate-sound-types",
    "generate-types": "ts-node ./src/scripts/generateTypes.ts",
    "generate-sound-types": "ts-node ./src/scripts/generateSoundTypes.ts",
    "sync-sounds": "ts-node ./src/scripts/syncSounds.ts",
    "clean-tts": "ts-node ./src/scripts/localTTS.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^20.19.43",
    "prettier": "^3.6.2",
