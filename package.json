    "typescript": "^5.2.2"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "dotenv": "^16.4.5",
    "fast-csv": "^5.0.2",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "glob": "^13.0.6",
    "google-tts-api": "^2.0.2"
  }
